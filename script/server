#!/usr/bin/env bash
# Run Flask on :5000 and Vite on :5173. Ctrl+C stops both.
set -uo pipefail
cd "$(dirname "$0")/.."

# Both ports are overridable so a machine where something else already owns 5000
# can still run the pair. Vite reads BACKEND_PORT too, so its /api proxy follows.
BACKEND_PORT="${BACKEND_PORT:-5000}"
FRONTEND_PORT="${FRONTEND_PORT:-5173}"
export BACKEND_PORT FRONTEND_PORT

. script/_common

if [ ! -f backend/app.py ]; then
  echo "ERROR: backend/app.py does not exist yet - run the build stage first." >&2
  exit 1
fi

PIDS=()
cleanup() {
  echo ""
  echo "==> Shutting down..."
  for pid in "${PIDS[@]+"${PIDS[@]}"}"; do
    kill "$pid" 2>/dev/null || true
  done
  wait 2>/dev/null || true
}
trap cleanup EXIT INT TERM

echo "==> Backend on http://localhost:$BACKEND_PORT"
(cd backend && FLASK_APP=app.py "../$VENV_PY" -m flask run --port "$BACKEND_PORT") &
PIDS+=($!)

if [ -f frontend/package.json ]; then
  echo "==> Frontend on http://localhost:$FRONTEND_PORT"
  # --strictPort: without it Vite silently falls back to the next free port when
  # FRONTEND_PORT is taken. You then get a working-looking app on :5174 whose /api
  # proxy still points at this run's backend, while the browser tab you actually
  # opened is served by some other, older instance. Fail loudly instead.
  (cd frontend && npm run dev -- --port "$FRONTEND_PORT" --strictPort) &
  PIDS+=($!)
else
  echo "frontend/package.json not found yet - backend only."
fi

wait

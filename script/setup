#!/usr/bin/env bash
# Install backend + frontend dependencies. Safe to re-run.
set -euo pipefail
cd "$(dirname "$0")/.."

. script/_common

echo "==> Backend"
if [ -f backend/requirements.txt ]; then
  # A previous interrupted run can leave a $VENV directory with no interpreter in
  # it, so key the creation off the interpreter rather than the directory.
  resolve_venv_py
  if [ -z "$VENV_PY" ]; then
    echo "Creating virtualenv at $VENV"
    rm -rf "$VENV"
    # Unquoted: $PYTHON may be "py -3", i.e. a command plus an argument.
    $PYTHON -m venv "$VENV"
    resolve_venv_py
    if [ -z "$VENV_PY" ]; then
      echo "ERROR: $VENV was created but has no interpreter in it." >&2
      exit 1
    fi
  fi
  "$VENV_PY" -m pip install --upgrade pip >/dev/null
  "$VENV_PY" -m pip install -r backend/requirements.txt
else
  echo "backend/requirements.txt not found yet - skipping (created during the build stage)."
fi

echo "==> Frontend"
if [ -f frontend/package.json ]; then
  if [ -f frontend/package-lock.json ]; then
    (cd frontend && npm ci)
  else
    (cd frontend && npm install)
  fi
else
  echo "frontend/package.json not found yet - skipping (created during the build stage)."
fi

echo "==> Done."
